{
  "name": "kra-system",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "build:web": "npm --workspace apps/web run build",
    "lint:web": "npm --workspace apps/web run lint",
    "lint:analytics": "python -m ruff check apps/analytics",
    "test:web": "npm --workspace apps/web run test",
    "test:api": ".\\mvnw.cmd -f apps/api/pom.xml test",
    "test:analytics": "python -m pytest apps/analytics",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "npm run lint:web && npm run lint:analytics",
    "test": "npm run test:web && npm run test:api && npm run test:analytics"
  },
  "devDependencies": {
    "prettier": "3.3.3"
  }
}
